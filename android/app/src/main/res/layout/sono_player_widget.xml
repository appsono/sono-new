<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
      full-bleed cover
      two-child flipper for skip slide
    -->
    <ViewFlipper
        android:id="@+id/widget_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@anim/widget_cover_slide_in"
        android:outAnimation="@anim/widget_cover_slide_out"
        android:visibility="gone">
        <ImageView
            android:id="@+id/widget_cover_a"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />
        <ImageView
            android:id="@+id/widget_cover_b"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />
    </ViewFlipper>

    <!-- fallback -->
    <FrameLayout
        android:id="@+id/widget_fallback"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ic_launcher_background"
        android:visibility="gone">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@null" />
    </FrameLayout>

    <ViewFlipper
        android:id="@+id/widget_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@anim/widget_overlay_fade_in"
        android:outAnimation="@anim/widget_overlay_fade_out">

        <!-- playing -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="bottom|start"
                android:layout_margin="14dp"
                android:src="@drawable/ic_widget_now_playing"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- paused -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/widget_overlay_scrim">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_play"
                android:contentDescription="@null" />
        </FrameLayout>
    </ViewFlipper>

    <!-- tap zones
         left previous, center play/pause, right next
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">
        <FrameLayout
            android:id="@+id/widget_zone_prev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
        <FrameLayout
            android:id="@+id/widget_zone_playpause"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
        <FrameLayout
            android:id="@+id/widget_zone_next"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />
    </LinearLayout>

</FrameLayout>
